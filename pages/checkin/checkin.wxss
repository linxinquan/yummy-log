  font-weight: 700;
  color: #1A1A2E;
}

.lc-addr-row {}

.lc-addr {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
}

.lc-action {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lc-refresh {
  font-size: 40rpx;
  color: #00C5FF;
  font-weight: 300;
}

@keyframes rotateCW {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.lc-refresh.spinning {
  animation: rotateCW 1s linear infinite;
  display: inline-block;
}

