  color: #009FD4;
}

.lc-dots {
  display: flex;
  gap: 4rpx;
  align-items: center;
}

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.ldot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #00C5FF;
}

.ldot:nth-child(1) { animation: dotPulse 1.2s ease-in-out infinite 0s; }
.ldot:nth-child(2) { animation: dotPulse 1.2s ease-in-out infinite 0.2s; }
.ldot:nth-child(3) { animation: dotPulse 1.2s ease-in-out infinite 0.4s; }

