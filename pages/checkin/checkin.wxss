  background: linear-gradient(135deg, #00D9C0, #00B5A6);
  color: #fff;
  border-radius: 20rpx;
  padding: 28rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(0,217,192,0.32);
  transition: all 0.2s;
}

.btn-collect:active { transform: scale(0.97); }
.btn-collect.loading { opacity: 0.75; }

