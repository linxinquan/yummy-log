}

.locate-card.loading {
  border-color: #00C5FF;
  box-shadow: 0 4rpx 20rpx rgba(0,197,255,0.14);
}

.lc-top {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.lc-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
