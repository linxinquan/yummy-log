/* ================================================
  觅食图 · 店铺详情页  v4.0 青绿色系
  ================================================ */

page {
  --primary: #00D9C0;
  --primary-dark: #00B5A6;
  --primary-light: #E8FAF8;
  --primary-bg: #F0F9F8;
}

.container {
  min-height: 100vh;
  background: #F0F9F8;
  padding-bottom: 160rpx;
}

/* ─── Cover Image ────────────────────────── */
.cover {
  width: 100%;
  height: 480rpx;
  background: #e0f7f5;
  position: relative;
}

.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-fallback {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
}

.cover-emoji {
  font-size: 120rpx;
}

.cover-back {
  position: absolute;
  top: env(safe-area-inset-top);
  left: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(0,0,0,0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  backdrop-filter: blur(8rpx);
}

/* ─── Content ─────────────────────────────── */
.content {
  padding: 0 24rpx;
}

/* 店铺基本信息卡片 */
.shop-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: -40rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,217,192,0.10);
  position: relative;
  z-index: 2;
  border: 1rpx solid rgba(0,217,192,0.06);
}

.shop-emoji {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.shop-name {
  font-size: 40rpx;
  font-weight: 900;
  color: #1A1A2E;
  margin-bottom: 12rpx;
  letter-spacing: -1rpx;
}

.shop-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.shop-rating {
  font-size: 32rpx;
  color: #FF8B7E;
  font-weight: 800;
}

.shop-price {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 500;
}

.shop-category {
  font-size: 24rpx;
  background: #F0F9F8;
  color: #00B5A6;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

/* 标签 */
.shop-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #FFF5F4;
  color: #FF8B7E;
}

/* 地址和营业时间 */
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-top: 1rpx solid #E5E7EB;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.info-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.5;
}

.info-arrow {
  font-size: 28rpx;
  color: #D1D5DB;
  flex-shrink: 0;
}

/* ─── Section ─────────────────────────────── */
.section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,217,192,0.06);
  border: 1rpx solid rgba(0,217,192,0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1A1A2E;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  font-size: 32rpx;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.recommend-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #F0F9F8;
  border-radius: 12rpx;
}

.recommend-rank {
  font-size: 28rpx;
  font-weight: 800;
  color: #00B5A6;
  width: 40rpx;
  text-align: center;
  flex-shrink: 0;
}

.recommend-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.recommend-price {
  font-size: 26rpx;
  color: #FF8B7E;
  font-weight: 600;
}

/* ─── Record Card (觅食记录) ──────────────────────── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.edit-record-btn {
  font-size: 26rpx;
  color: #FF8B7E;
  font-weight: 600;
}

.record-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,217,192,0.08);
  border: 1rpx solid rgba(0,217,192,0.06);
}

/* 记录内容区 */
.record-body {
  padding: 24rpx;
}

.record-rating {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stars-row {
  display: flex;
  gap: 6rpx;
}

.star-item {
  font-size: 36rpx;
  color: #E5E7EB;
  transition: all 0.2s;
}

.star-item.active {
  color: #FFB800;
}

.rating-text {
  font-size: 28rpx;
  color: #FF8B7E;
  font-weight: 700;
}

.record-content {
  margin-bottom: 16rpx;
}

.comment-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-dot {
  width: 8rpx;
  height: 8rpx;
  background: #00D9C0;
  border-radius: 50%;
}

.meta-date {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 记录卡片中的定位信息 */
.record-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 16rpx;
  background: #F0F9F8;
  border-radius: 8rpx;
  width: fit-content;
}

.location-icon-small {
  font-size: 24rpx;
}

.location-text-small {
  font-size: 24rpx;
  color: #00B5A6;
}

/* 未记录状态 */
.empty-record {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,217,192,0.08);
  border: 2rpx dashed rgba(0,217,192,0.25);
}

.empty-record-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-fork {
  font-size: 48rpx;
}

.empty-record-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}

.empty-record-btn {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 14rpx rgba(0,217,192,0.25);
}

/* ─── Bottom Bar ─────────────────────────── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  gap: 16rpx;
}

.bottom-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  transition: all 0.18s;
}

.bottom-btn::after {
  border: none;
}

.bottom-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.bottom-btn.want {
  background: #F0F9F8;
  color: #00B5A6;
}

.bottom-btn.want.active {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(0,217,192,0.30);
}

.bottom-btn.nav {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0,217,192,0.35);
}

.bottom-btn.checkin {
  background: var(--primary-bg);
  color: var(--primary-dark);
  border: 1.5rpx solid rgba(0,217,192,0.3);
}

.bottom-btn.checkin.active {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0,217,192,0.25);
}

/* ─── Modal ──────────────────────────────── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 999;
  backdrop-filter: blur(4rpx);
}

.modal-content {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  overflow-y: auto;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-handle {
  width: 72rpx;
  height: 6rpx;
  background: #E5E7EB;
  border-radius: 999rpx;
  margin: 18rpx auto 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1A1A2E;
  text-align: center;
  padding: 24rpx 32rpx 16rpx;
}

.star-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
}

.star-btn {
  font-size: 60rpx;
  transition: transform 0.15s;
}

.star-btn.active {
  transform: scale(1.2);
}

.modal-textarea {
  width: calc(100% - 48rpx);
  min-height: 160rpx;
  background: #F0F9F8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1A1A2E;
  margin: 0 24rpx 24rpx;
  box-sizing: border-box;
  border: 1.5rpx solid rgba(0,217,192,0.1);
}

.modal-submit {
  width: calc(100% - 48rpx);
  height: 88rpx;
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,217,192,0.35);
}

.modal-cancel {
  text-align: center;
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 0 24rpx 24rpx;
}

/* ─── 底部操作栏（详情页）─────────────────────────────── */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.action-main {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 16rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.18s;
  background: var(--primary-bg);
  color: var(--primary-dark);
  border: 1.5rpx solid rgba(0,217,192,0.25);
}

.action-btn.liked {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0,217,192,0.25);
}

.action-btn.checked {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0,217,192,0.25);
}

.action-btn.primary {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0,217,192,0.25);
  flex: 1.2;
}

.action-icon {
  font-size: 32rpx;
  line-height: 1;
}

.action-text {
  font-size: 26rpx;
  font-weight: 600;
}
