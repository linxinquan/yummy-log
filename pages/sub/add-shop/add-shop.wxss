/* ================================================
  觅食图 · 添加店铺页  v4.0 青绿色系
  ================================================ */

.container {
  min-height: 100vh;
  background: #F0F9F8;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ─── Section ─────────────────────────────── */
.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,217,192,0.06);
  border: 1rpx solid rgba(0,217,192,0.06);
}

.form-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 18rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F0F9F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #1A1A2E;
  border: 1.5rpx solid rgba(0,217,192,0.1);
  transition: border-color 0.18s;
}

.form-input:focus {
  border-color: #00D9C0;
  background: #ffffff;
}

/* ─── Category Pills ─────────────────────── */
.category-select {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.cat-pill {
  padding: 12rpx 26rpx;
  background: #F0F9F8;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #6B7280;
  transition: all 0.18s;
  border: 1rpx solid rgba(0,217,192,0.1);
}

.cat-pill.active {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 14rpx rgba(0,217,192,0.30);
}

/* ─── Emoji Select ─────────────────────────── */
.emoji-select {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.emoji-item {
  font-size: 50rpx;
  padding: 10rpx;
  background: #F0F9F8;
  border-radius: 12rpx;
  transition: all 0.18s;
  border: 2rpx solid transparent;
}

.emoji-item.active {
  background: #F0F9F8;
  box-shadow: 0 0 0 3rpx #00D9C0;
  border-color: #00D9C0;
}

/* ─── 🗺️ Map Choose Button ─────────────── */
.choose-location-btn {
  display: flex;
  align-items: center;
  background: #F0F9F8;
  border: 2rpx solid #00D9C0;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.choose-loc-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.choose-loc-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.choose-loc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #00B5A6;
}

.choose-loc-sub {
  font-size: 24rpx;
  color: #9CA3AF;
}

.choose-loc-arrow {
  font-size: 40rpx;
  color: #00D9C0;
  font-weight: bold;
}

/* ─── Coord Input ─────────────────────────── */
.coord-hint {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.coord-row {
  display: flex;
  gap: 16rpx;
}

.coord-input {
  flex: 1;
}

.quick-coord {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #00B5A6;
  font-weight: 600;
}

/* ─── Map Picker ──────────────────────────── */
.map-picker {
  position: relative;
  height: 380rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,217,192,0.06);
  border: 1rpx solid rgba(0,217,192,0.06);
}

.map {
  width: 100%;
  height: 100%;
}

.map-center-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 50rpx;
  z-index: 10;
  pointer-events: none;
}

/* ─── Submit Button ──────────────────────── */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0,217,192,0.35);
  letter-spacing: 0.5rpx;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  opacity: 0.9;
  transform: scale(0.98);
}
