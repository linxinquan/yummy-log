/* pages/collection/collection.wxss */

page {
  background: #F8F4F0;
}

.page {
  min-height: 100vh;
  background: #F8F4F0;
  padding-bottom: 120rpx;
}

/* 顶部统计横幅 */
.hero-bar {
  background: linear-gradient(135deg, #C0392B 0%, #8E2B2B 100%);
  padding: 40rpx 32rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2rpx;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hs-item {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.hs-num {
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.hs-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
}

.hs-sep {
  font-size: 28rpx;
  color: rgba(255,255,255,0.4);
}

/* 视图切换 Tab */
.view-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #F0EDE8;
}

.vt-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  transition: all 0.2s;
  border-bottom: 4rpx solid transparent;
}

.vt-item.active {
  color: #C0392B;
  border-bottom-color: #C0392B;
  font-weight: 700;
}

.vt-icon {
  font-size: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.empty-btn {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #C0392B, #96281B);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 24rpx 56rpx;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 24rpx rgba(192,57,43,0.3);
}

/* 邮票网格 */
.stamps-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 20rpx;
  gap: 20rpx;
}

.stamp-item {
  width: calc(50% - 10rpx);
}

.stamp-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow:
    0 0 0 3rpx #fff,
    0 0 0 5rpx #C0392B,
    0 6rpx 24rpx rgba(0,0,0,0.12);
  position: relative;
}

.stamp-card::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 0;
  right: 0;
  height: 16rpx;
  background: radial-gradient(circle at 50% 100%, #F8F4F0 8rpx, #fff 8rpx) 0 0 / 20rpx 16rpx repeat-x;
  z-index: 1;
}

.stamp-card::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 0;
  right: 0;
  height: 16rpx;
  background: radial-gradient(circle at 50% 0%, #F8F4F0 8rpx, #fff 8rpx) 0 0 / 20rpx 16rpx repeat-x;
  z-index: 1;
}

.stamp-photo-wrap {
  position: relative;
  width: 100%;
  height: 220rpx;
  overflow: hidden;
}

.stamp-photo {
  width: 100%;
  height: 100%;
}

.stamp-postmark {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(192,57,43,0.85);
  border-radius: 50%;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.6);
}

.pm-date {
  font-size: 14rpx;
  color: #fff;
  font-weight: 700;
  text-align: center;
  line-height: 1.3;
}

.stamp-info {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  background: #fff;
}

.stamp-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #1A1A1A;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.stamp-addr {
  font-size: 20rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 地图视图 */
.map-wrap {
  width: 100%;
  height: 65vh;
}

.collection-map {
  width: 100%;
  height: 100%;
}

.map-list {
  width: 100%;
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.map-card {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  background: #F8F4F0;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-right: 16rpx;
  width: 280rpx;
  white-space: normal;
}

.mc-photo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.mc-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}

.mc-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mc-date {
  font-size: 20rpx;
  color: #999;
}

/* 浮动采集按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #C0392B, #96281B);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(192,57,43,0.45);
  z-index: 100;
  gap: 2rpx;
}

.fab:active {
  transform: scale(0.93);
}

.fab-icon {
  font-size: 44rpx;
  color: #fff;
  line-height: 1;
  font-weight: 300;
}

.fab-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

/* 类型标签 */
.stamp-type-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8rpx);
  border-radius: 30rpx;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #333;
  z-index: 2;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}

/* 空状态第二个按钮 */
.empty-btn.secondary {
  background: linear-gradient(135deg, #2D6A4F, #1B4332);
  box-shadow: 0 6rpx 24rpx rgba(45,106,79,0.3);
  margin-top: 12rpx;
}

/* 地图卡片图标 */
.mc-icon {
  font-size: 24rpx;
}
