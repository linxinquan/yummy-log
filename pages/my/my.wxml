<!-- 觅食图 · 我的页面 v10.2 - 圆周旅迹风格 -->
<view class="page">

  <!-- ══ 顶部标题栏（标题 + 用户信息 + 设置） ══ -->
  <view class="page-header">
    <text class="page-title">我的采集</text>
    <!-- 已登录：右侧头像 + 昵称 -->
    <view class="header-user" wx:if="{{isLoggedIn}}" bindtap="onEditProfile">
      <text class="hu-nickname">{{userInfo.nickName || '觅食者'}}</text>
      <image class="hu-avatar" src="{{userInfo.avatarUrl || '/images/app-logo.jpg'}}" mode="aspectFill" />
    </view>
    <!-- 未登录：右侧登录入口 -->
    <view class="header-user-login" wx:else bindtap="onShowLogin">
      <text class="hul-text">登录</text>
      <image class="hul-avatar" src="{{avatarUrl}}" mode="aspectFill" />
    </view>
    <view class="icon-btn" bindtap="onEditProfile">
      <text class="iconfont icon-settings">✦</text>
    </view>
  </view>

  <!-- ══ 采集统计条（独立卡片，无用户信息） ══ -->
  <view class="stats-bar-card">
    <view class="stats-bar">
      <view class="sb-stat">
        <text class="sb-num">{{checkinStats.totalCount || 0}}</text>
        <text class="sb-label">采集</text>
      </view>
      <view class="sb-div"></view>
      <view class="sb-stat">
        <text class="sb-num">{{checkinStats.cityCount || 0}}</text>
        <text class="sb-label">城市</text>
      </view>
      <view class="sb-div"></view>
      <view class="sb-stat">
        <text class="sb-num sb-spot">{{checkinStats.spotCount || 0}}</text>
        <text class="sb-label">景点</text>
      </view>
      <view class="sb-div"></view>
      <view class="sb-stat">
        <text class="sb-num sb-food">{{checkinStats.foodCount || 0}}</text>
        <text class="sb-label">美食</text>
      </view>
      <view class="sb-stamp" wx:if="{{latestStamp}}" bindtap="onPreviewStamp" data-id="{{latestStamp.id}}">
        <image class="sb-stamp-img" src="{{latestStamp.photoPath}}" mode="aspectFill" />
        <view class="sb-stamp-date">{{latestStamp.dateStr}}</view>
      </view>
    </view>
  </view>

  <!-- ══ 采集快捷入口 ══ -->
  <view class="entry-cards">
    <view class="entry-card food" bindtap="onGoCheckinFood">
      <view class="ec-icon food-icon">✦</view>
      <view class="ec-info">
        <text class="ec-title">美食采集</text>
        <text class="ec-sub">记录探店瞬间</text>
      </view>
      <text class="ec-arrow">›</text>
    </view>
    <view class="entry-card spot" bindtap="onGoCheckinSpot">
      <view class="ec-icon spot-icon">✦</view>
      <view class="ec-info">
        <text class="ec-title">景点采集</text>
        <text class="ec-sub">打卡城市地标</text>
      </view>
      <text class="ec-arrow">›</text>
    </view>
  </view>

  <!-- ══ 双地图横向滚动（数据可视化版）══════════════════════════════════════ -->
  <view class="journey-section">
    <scroll-view class="journey-scroll" scroll-x enable-flex bindscroll="onJourneyScroll">
      <!-- 景点地图大卡片 -->
      <view class="journey-card spot" bindtap="onSpotMapTap">
        <view class="jc-header">
          <view class="jc-title-row">
            <text class="jc-emoji spot-icon">✦</text>
            <text class="jc-title">景点地图</text>
            <view class="jc-badge spot" wx:if="{{spotMarkers.length > 0}}">{{spotMarkers.length}}个</view>
          </view>
          <text class="jc-sub">{{spotMarkers.length > 0 ? '点亮你的城市地标' : '还没有景点打卡'}}</text>
        </view>
        <view class="jc-map-wrap">
          <!-- 数据可视化地图：支持 markers 最优缩放 -->
          <map 
            class="jc-map" 
            id="spotMap"
            latitude="{{spotMapCenter.latitude}}" 
            longitude="{{spotMapCenter.longitude}}" 
            scale="{{spotMarkers.length > 0 ? 11 : 10}}" 
            markers="{{spotMarkers}}"
            show-location
            enable-overlooking="false"
            enable-zoom="true"
            enable-scroll="true"
            bindtap="onSpotMapTap"
          ></map>
          <view class="jc-circle-overlay"></view>
          <!-- 数据可视化层 - 打卡点脉冲效果 -->
          <view class="jc-data-viz" wx:if="{{spotMarkers.length > 0}}">
            <view class="jdv-pulse jdv-pulse-1"></view>
            <view class="jdv-pulse jdv-pulse-2"></view>
            <view class="jdv-pulse jdv-pulse-3"></view>
          </view>
          <view class="jc-empty" wx:if="{{spotMarkers.length === 0}}">
            <view class="jce-icon">🏞</view>
            <text class="jce-text">去采集景点</text>
            <view class="jce-btn">开始 ›</view>
          </view>
        </view>
      </view>

      <!-- 美食地图大卡片 -->
      <view class="journey-card food" bindtap="onFoodMapTap">
        <view class="jc-header">
          <view class="jc-title-row">
            <text class="jc-emoji food-icon">✦</text>
            <text class="jc-title">美食地图</text>
            <view class="jc-badge food" wx:if="{{foodMarkers.length > 0}}">{{foodMarkers.length}}家</view>
          </view>
          <text class="jc-sub">{{foodMarkers.length > 0 ? '记录舌尖上的美味' : '还没有美食打卡'}}</text>
        </view>
        <view class="jc-map-wrap">
          <!-- 数据可视化地图 -->
          <map 
            class="jc-map" 
            id="foodMap"
            latitude="{{foodMapCenter.latitude}}" 
            longitude="{{foodMapCenter.longitude}}" 
            scale="{{foodMarkers.length > 0 ? 11 : 10}}" 
            markers="{{foodMarkers}}"
            show-location
            enable-overlooking="false"
            enable-zoom="true"
            enable-scroll="true"
            bindtap="onFoodMapTap"
          ></map>
          <view class="jc-circle-overlay"></view>
          <!-- 数据可视化层 - 打卡点脉冲效果 -->
          <view class="jc-data-viz" wx:if="{{foodMarkers.length > 0}}">
            <view class="jdv-pulse jdv-pulse-1"></view>
            <view class="jdv-pulse jdv-pulse-2"></view>
            <view class="jdv-pulse jdv-pulse-3"></view>
          </view>
          <view class="jc-empty" wx:if="{{foodMarkers.length === 0}}">
            <view class="jce-icon">🍜</view>
            <text class="jce-text">去采集美食</text>
            <view class="jce-btn">开始 ›</view>
          </view>
        </view>
      </view>
    </scroll-view>
    
    <!-- 滚动指示器 -->
    <view class="journey-indicator">
      <view class="ji-dot {{journeyIndex === 0 ? 'active' : ''}}"></view>
      <view class="ji-dot {{journeyIndex === 1 ? 'active' : ''}}"></view>
    </view>
  </view>

  <!-- ══ 近期采集横向滚动 ══ -->
  <view class="recent-section" wx:if="{{recentStamps.length > 0}}">
    <view class="section-header">
      <text class="section-title">近期采集</text>
      <text class="section-more" bindtap="onGoCollection">查看全部 ›</text>
    </view>
    <scroll-view class="stamp-scroll" scroll-x enable-flex>
      <view class="stamp-thumb" wx:for="{{recentStamps}}" wx:key="id" bindtap="onPreviewStamp" data-id="{{item.id}}">
        <image class="st-photo" src="{{item.photoPath}}" mode="aspectFill" />
        <view class="st-tag {{item.type === 'spot' ? 'spot' : 'food'}}">{{item.type === 'spot' ? '🏞️' : '🍜'}}</view>
        <view class="st-date">{{item.shortDate}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- ══ 用户菜单 ══ -->
  <view class="user-menu">
    <view class="menu-grid">
      <view class="menu-item" bindtap="onMenuTap" data-type="favorites">
        <text class="menu-icon heart-icon">♡</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <view class="menu-item" bindtap="onMenuTap" data-type="history">
        <text class="menu-icon">📍</text>
        <text class="menu-text">觅食足迹</text>
      </view>
      <view class="menu-item" bindtap="onMenuTap" data-type="guides">
        <text class="menu-icon">📝</text>
        <text class="menu-text">我的攻略</text>
      </view>
      <view class="menu-item" bindtap="onMenuTap" data-type="settings">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
      </view>
      <view class="menu-item" bindtap="onGoCollection">
        <text class="menu-icon">🎫</text>
        <text class="menu-text">采集本</text>
      </view>
    </view>
  </view>

  <!-- ══ 想去清单入口 ══ -->
  <view class="wantgo-entry-wrap">
    <view wx:if="{{likedShops.length === 0}}" class="empty-state">
      <text class="empty-icon heart-icon">♡</text>
      <text class="empty-text">还没有想去的店铺</text>
      <text class="empty-hint">去首页收藏喜欢的店铺吧</text>
    </view>
    <view wx:else class="wantgo-card" bindtap="onGoWantgo">
      <view class="wc-header">
        <view class="wc-logo-stack">
          <block wx:for="{{likedShops}}" wx:key="id">
            <image wx:if="{{index < 4}}" class="wc-logo-item" src="{{item.logo || '/images/app-logo.jpg'}}" mode="aspectFill" style="z-index:{{4-index}}; margin-left:{{index === 0 ? '0' : '-24rpx'}}" />
          </block>
          <view wx:if="{{likedShops.length > 4}}" class="wc-logo-more"><text>+{{likedShops.length - 4}}</text></view>
        </view>
        <view class="wc-count-wrap">
          <text class="wc-count">{{likedShops.length}}</text>
          <text class="wc-count-lbl">家想去</text>
        </view>
      </view>
      <view class="wc-footer">
        <view class="wc-footer-left">
          <text class="wc-title">查看想去清单</text>
          <text class="wc-sub">管理收藏 · 一键规划路线</text>
        </view>
        <view class="wc-arrow-btn"><text class="wc-arrow">›</text></view>
      </view>
      <view class="wc-actions">
        <view class="wca-btn primary" catchtap="onGoRoute"><text class="wca-icon">🗺️</text><text class="wca-text">规划路线</text></view>
        <view class="wca-btn" catchtap="onGoWantgo"><text class="wca-icon">❤️</text><text class="wca-text">管理清单</text></view>
      </view>
    </view>
  </view>

  <!-- ══ 已到访列表 ══ -->
  <view class="shop-list">
    <view wx:if="{{visitedList.length === 0}}" class="empty-state">
      <text class="empty-icon">🍴</text>
      <text class="empty-text">还没有觅食记录</text>
      <text class="empty-hint">去店铺详情页标记到访吧</text>
    </view>
    <view wx:for="{{visitedList}}" wx:key="shopId" class="record-card" bindtap="onShopTap" data-shop="{{item.shop}}">
      <view class="record-header">
        <image class="record-img" src="https://apis.map.qq.com/ws/staticmap/v2?key=YLOBZ-VDFWB-AMSUJ-JCOQQ-GJ633-CTBR5&center={{item.shop.lat}},{{item.shop.lng}}&zoom=16&size=120x120&markers={{item.shop.lat}},{{item.shop.lng}},red" mode="aspectFill" />
        <view class="record-info">
          <text class="record-name">{{item.shop.name}}</text>
          <view class="record-stars">
            <text wx:for="{{5}}" wx:for-item="s" wx:key="index" class="star {{index < item.data.rating ? 'active' : ''}}">⭐</text>
          </view>
        </view>
        <text class="record-date">{{item.data.dateStr}}</text>
      </view>
      <text wx:if="{{item.data.comment}}" class="record-comment">{{item.data.comment}}</text>
    </view>
  </view>

  <!-- ══ 用户添加列表 ══ -->
  <view class="shop-list">
    <view class="add-hint">
      <text>你添加的店铺</text>
      <view class="add-btn" bindtap="onAddShop"><text>➕ 添加新店</text></view>
    </view>
    <view wx:if="{{userAddedShops.length === 0}}" class="empty-state">
      <text class="empty-icon">➕</text>
      <text class="empty-text">还没有添加新店</text>
      <text class="empty-hint">发现了好吃的可以分享给大家哦</text>
    </view>
    <view wx:for="{{userAddedShops}}" wx:key="id" class="shop-card" bindtap="onShopTap" data-shop="{{item}}">
      <image class="shop-img" src="https://apis.map.qq.com/ws/staticmap/v2?key=YLOBZ-VDFWB-AMSUJ-JCOQQ-GJ633-CTBR5&center={{item.lat}},{{item.lng}}&zoom=16&size=120x120&markers={{item.lat}},{{item.lng}},red" mode="aspectFill" />
      <view class="shop-info">
        <text class="shop-name">{{item.name}}</text>
        <text class="shop-meta">{{item.category}} · {{item.address}}</text>
      </view>
      <view class="shop-action">
        <view class="remove-btn" catchtap="onDeleteShop" data-shopid="{{item.id}}">🗑️</view>
      </view>
    </view>
  </view>

</view>
