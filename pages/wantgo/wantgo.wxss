/* 觅食图 V1 - 想去清单页样式 */
page {
  --primary: #00D9C0;
  --primary-dark: #00B5A6;
  --primary-light: #E8FAF8;
  --primary-bg: #F0F9F8;
  --accent: #FF8B7E;
  --text-1: #1A1A2E;
  --text-2: #6B7280;
  --text-3: #9CA3AF;
  --card: #FFFFFF;
  --bg: #F4FAFA;
  --r-sm: 12rpx;
  --r-md: 16rpx;
  --r-lg: 24rpx;
  --r-pill: 999rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.05);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.container {
  height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-top: calc(228rpx + env(safe-area-inset-top));
  box-sizing: border-box;
}

/* ── 顶部导航栏 ── */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  background: var(--card);
  box-shadow: 0 1rpx 0 #F0F0F0;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: 50%;
  flex-shrink: 0;
}

.nav-back-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: var(--primary-dark);
  line-height: 1;
  margin-top: -4rpx;
}

.nav-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-1);
  letter-spacing: -0.5rpx;
}

.nav-right-placeholder {
  width: 72rpx;
}

.nav-shortcuts {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.shortcut-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: 50%;
  font-size: 28rpx;
}

/* ── Tab切换 ── */
.tab-bar {
  display: flex;
  background: var(--card);
  padding: 0 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: fixed;
  top: calc(184rpx + env(safe-area-inset-top));
  left: 0;
  right: 0;
  z-index: 19;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-3);
  position: relative;
}

.tab-item.active {
  color: var(--primary-dark);
}

.tab-item text {
  font-size: 28rpx;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

/* ── 空状态 ── */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 80rpx;
}

.empty-illustration {
  width: 160rpx;
  height: 160rpx;
  background: var(--primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-3);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.empty-btn {
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #FFF;
  border-radius: var(--r-pill);
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(0,217,192,0.35);
}

/* ── 规划路线横幅 ── */
.route-banner {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #00D9C0 0%, #00A896 100%);
  border-radius: var(--r-lg);
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(0,217,192,0.35);
  position: relative;
  overflow: hidden;
}

.route-banner::before {
  content: '';
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.banner-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.banner-icon {
  font-size: 40rpx;
}

.banner-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  z-index: 1;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.banner-arrow-wrap {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.banner-arrow {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ── 拖拽提示 ── */
.sort-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 0;
  font-size: 22rpx;
  color: var(--text-3);
}

.tip-icon {
  font-size: 22rpx;
}

.tip-text {
  font-size: 22rpx;
}

/* ── 可拖拽列表 ── */
.item-list {
  flex: 1;
  width: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 16rpx 24rpx 40rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.item-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  height: 150rpx;
  background: var(--card);
  border-radius: var(--r-lg);
  padding: 0 20rpx 0 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 1rpx solid rgba(0,0,0,0.04);
  box-sizing: border-box;
  margin-bottom: 24rpx;
  transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
}

.item-card.dragging {
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  opacity: 0.9;
  background: #FFFDF5;
  transform: scale(1.02);
}

/* 拖拽手柄 */
.drag-handle {
  width: 44rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #CBD5E1;
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 序号 */
.item-num {
  width: 44rpx;
  height: 44rpx;
  background: var(--primary-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-num text {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--primary-dark);
}

/* 图片 */
.item-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--r-md);
  flex-shrink: 0;
  background: var(--primary-light);
}

.item-img.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* 信息区 */
.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 2rpx;
  overflow: hidden;
}

.item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}

.item-meta {
  font-size: 22rpx;
  color: var(--text-2);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}

.item-address {
  font-size: 22rpx;
  color: var(--text-3);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}

/* 右侧操作 */
.item-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
  width: 60rpx;
}

.navi-btn,
.remove-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.navi-btn {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.remove-btn {
  background: #FFF0F0;
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 700;
}

