/* ================================================
  觅食图 · 首页  v7.0 小红书定位风格
  配色参考：LOGO #00D9C0 青绿色
  ================================================ */

/* ─── 设计令牌 ─────────────────────────────── */
page {
  --primary: #00D9C0;
  --primary-dark: #00B5A6;
  --primary-light: #E8FAF8;
  --primary-bg: #F0F9F8;
  --accent: #FF8B7E;
  --accent-soft: #FFF5F4;
  --text-primary: #1A1A2E;
  --text-secondary: #6B7280;
  --text-hint: #9CA3AF;
  --text-on-primary: #FFFFFF;
  --bg: #FFFFFF;
  --bg-card: #FFFFFF;
  --border: #F0F0F0;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 6rpx 24rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 12rpx 40rpx rgba(0,0,0,0.12);
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 999rpx;
}

/* ─── Container ─────────────────────────────── */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─── Header ─────────────────────────────────── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx 12rpx;
  background: var(--bg);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.app-brand {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* 品牌Logo图片 */
.logo-img {
  width: 52rpx;
  height: 52rpx;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,217,192,0.20);
}

.logo-text {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 1.5rpx;
}

/* 位置选择器 - 小红书风格 */
.location-selector {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: var(--primary-bg);
  border-radius: var(--radius-pill);
  border: 1rpx solid rgba(0,217,192,0.2);
}

.location-main {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.location-arrow {
  font-size: 18rpx;
  color: var(--primary);
}

.weather {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--primary-bg);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-pill);
}

.weather-icon {
  font-size: 26rpx;
}

.weather-temp {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ─── 地理探索卡片区域 ─────────────────────────── */
.explore-section {
  padding: 0 24rpx 16rpx;
  display: flex;
  gap: 16rpx;
}

/* 小地图预览卡片 */
.mini-map-card {
  width: 200rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border);
}

.mini-map {
  width: 100%;
  height: 100%;
}

.mini-map-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  padding: 8rpx 12rpx;
}

.mini-map-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 距离筛选胶囊 */
.distance-scroll {
  flex: 1;
  white-space: nowrap;
}

.distance-list {
  display: inline-flex;
  gap: 10rpx;
  padding: 4rpx 0;
}

.distance-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: var(--bg);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
}

.distance-pill.active {
  background: var(--primary);
  border-color: var(--primary);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0,217,192,0.3);
}

/* ─── 美食分类列表（美团风格）────────────────────────────── */
.category-section {
  padding: 20rpx 0 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.category-header {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.category-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 24rpx;
}

.category-chip {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 20rpx;
  background: #ffffff;
  border: 1.5rpx solid #F0F0F0;
  border-radius: 40rpx;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.25s;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.category-chip.active {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(0,217,192,0.3);
}

.category-icon {
  font-size: 10rpx;
  line-height: 1;
}

.category-chip.active .category-icon {
  transform: scale(1.1);
}

.category-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
}

.category-chip.active .category-name {
  color: #ffffff;
}

/* ─── 美食分类列表（紧凑版-搜索栏下方）─────────────────────── */
.category-section-compact {
  padding: 0 0 14rpx;
  background: var(--bg-card);
}

.category-list-compact {
  display: inline-flex;
  gap: 8rpx;
  padding: 0 24rpx;
}

.category-chip-compact {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: var(--bg);
  border: 1rpx solid var(--border);
  border-radius: 32rpx;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
}

.category-chip-compact.active {
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  border-color: transparent;
  box-shadow: 0 2rpx 8rpx rgba(0,217,192,0.25);
}

.category-icon-compact {
  font-size: 20rpx;
  line-height: 1;
}

.category-chip-compact.active .category-icon-compact {
  transform: scale(1.05);
}

.category-name-compact {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
  white-space: nowrap;
}

.category-chip-compact.active .category-name-compact {
  color: #ffffff;
  font-weight: 600;
}

/* ─── Map Container ─────────────────────────── */
.map-container {
  position: relative;
  height: 32vh;
  min-height: 260rpx;
}

.map {
  width: 100%;
  height: 100%;
}

/* ── 地图图层切换按钮 ── */
.map-layer-btns {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0;
  background: rgba(255,255,255,0.95);
  border-radius: 32rpx;
  padding: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
  z-index: 10;
}

.layer-btn {
  font-size: 22rpx;
  padding: 10rpx 22rpx;
  border-radius: 26rpx;
  color: #6B7280;
  font-weight: 500;
  transition: all 0.2s;
  white-space: nowrap;
}

.layer-btn.active {
  background: #00D9C0;
  color: #ffffff;
  font-weight: 700;
}

.location-btn {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  width: 88rpx;
  height: 88rpx;
  background: var(--bg-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
  z-index: 10;
  border: 2rpx solid var(--primary-bg);
}

.location-icon {
  font-size: 34rpx;
  color: var(--primary);
}

/* ─── Shop List Container ─────────────────── */
.shop-list-container {
  background: var(--bg-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  margin-top: -16rpx;
  position: relative;
  z-index: 5;
  min-height: 50vh;
  border-top: 2rpx solid var(--border);
}

/* 顶部把手条 */
.shop-list-container::before {
  content: '';
  display: block;
  width: 72rpx;
  height: 5rpx;
  background: var(--border);
  border-radius: var(--radius-pill);
  margin: 14rpx auto 0;
}

/* ─── Search Bar ───────────────────────────── */
.search-bar {
  padding: 16rpx 24rpx 14rpx;
}

.search-box {
  background: var(--primary-bg);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 76rpx;
  border: 1.5rpx solid rgba(0,217,192,0.15);
}

.search-box:focus-within {
  border-color: var(--primary);
  box-shadow: 0 0 0 3rpx rgba(0,217,192,0.1);
}

.search-icon {
  font-size: 28rpx;
  color: var(--primary);
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
}

/* ─── List Header ─────────────────────────── */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 24rpx 14rpx;
}

.list-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.sort-btns {
  display: flex;
  gap: 0;
  background: var(--primary-bg);
  border-radius: var(--radius-pill);
  padding: 4rpx;
}

.sort-btn {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  padding: 8rpx 24rpx;
  border-radius: var(--radius-pill);
  transition: all 0.2s;
  white-space: nowrap;
}

.sort-btn.active {
  background: var(--text-primary);
  color: #ffffff;
}

/* ─── Shop List ─────────────────────────────── */
.shop-list {
  height: calc(100vh - 32vh - 380rpx);
  min-height: 400rpx;
}

/* ─── Shop Card ─────────────────────────────── */
.shop-card {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  transition: background 0.12s;
}

.shop-card:active {
  background: var(--primary-bg);
}

/* 缩略图 - 门面照片 */
.shop-thumb-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
  background: var(--primary-bg);
  border: 1.5rpx solid rgba(0,217,192,0.1);
}

.shop-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.shop-thumb.hidden {
  opacity: 0;
}

.shop-thumb-fallback {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--primary-light) 0%, #E8FAF8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.25s;
}

.shop-thumb-fallback.show {
  opacity: 1;
}

.fallback-text {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}

/* 店铺LOGO样式 */
.shop-logo {
  object-fit: cover;
}

/* emoji占位符（无LOGO时显示） */
.shop-emoji-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-light) 0%, #E8FAF8 100%);
}

.shop-emoji {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.shop-emoji-hint {
  font-size: 16rpx;
  color: var(--text-hint);
  text-align: center;
  padding: 0 8rpx;
  line-height: 1.3;
}

/* 分类徽章 */
.shop-category-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 4rpx 12rpx;
  font-size: 18rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,217,192,0.35);
}

/* 距离徽章 */
.distance-badge {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: rgba(0,0,0,0.65);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 4rpx 10rpx;
  font-size: 18rpx;
  font-weight: 500;
}

/* 店铺信息 */
.shop-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}

.shop-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.shop-rating {
  color: var(--accent);
  font-weight: 700;
}

.rating-dot {
  width: 4rpx;
  height: 4rpx;
  background: var(--border);
  border-radius: 50%;
}

.shop-price {
  font-weight: 500;
  color: var(--text-secondary);
}

.shop-category {
  font-size: 22rpx;
  background: var(--primary-bg);
  color: var(--primary-dark);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-pill);
  font-weight: 600;
}

.shop-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 500;
  background: var(--accent-soft);
  color: var(--accent);
}

/* ─── 底部行：统计 + 操作图标 ───────────────── */
.shop-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

/* 社交数据统计区 */
.shop-stats {
  display: flex;
  align-items: center;
  gap: 0;
  flex: 1;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 5rpx;
}

.stat-icon {
  font-size: 20rpx;
  line-height: 1;
}

.stat-num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-hint);
  font-weight: 400;
}

.stat-divider {
  width: 1rpx;
  height: 22rpx;
  background: var(--border);
  margin: 0 14rpx;
}

/* 右侧小图标操作按钮组 */
.shop-action-icons {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.icon-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1.5rpx solid rgba(0,217,192,0.15);
  transition: all 0.18s;
}

.icon-btn:active {
  transform: scale(0.90);
}

.icon-btn-text {
  font-size: 26rpx;
  line-height: 1;
}

/* 已想去状态 */
.icon-btn.want-icon.liked {
  background: linear-gradient(135deg, #FF8B7E 0%, #ff6b6b 100%);
  border-color: transparent;
  box-shadow: 0 3rpx 10rpx rgba(255,139,126,0.35);
}

/* ─── Load More ─────────────────────────────── */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: var(--text-hint);
}

/* ─── Route Float Button ───────────────────── */
.route-float-btn {
  position: fixed;
  right: 24rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #00D9C0 0%, #00B5A6 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(0,217,192,0.40);
  z-index: 100;
  opacity: 0;
  transform: scale(0.4);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.route-float-btn.show {
  opacity: 1;
  transform: scale(1);
}

.route-icon {
  font-size: 36rpx;
  line-height: 1;
}

.route-float-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 700;
  margin-top: 2rpx;
}

.route-count {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: var(--accent);
  color: #ffffff;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 2.5rpx solid #ffffff;
}

/* ─── 位置选择器弹窗 ─────────────────────────── */
.location-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0);
  z-index: 1000;
  pointer-events: none;
  transition: background 0.3s;
}

.location-picker-mask.show {
  background: rgba(0,0,0,0.4);
  pointer-events: auto;
}

.location-picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  z-index: 1001;
}

.location-picker-mask.show .location-picker-panel {
  transform: translateY(0);
}

.picker-handle {
  width: 72rpx;
  height: 5rpx;
  background: var(--border);
  border-radius: var(--radius-pill);
  margin: 14rpx auto 0;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-hint);
}

.picker-content {
  padding: 24rpx 32rpx;
  max-height: 55vh;
  overflow-y: auto;
}

.picker-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.city-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.city-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: var(--bg);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-pill);
  transition: all 0.2s;
}

.city-item.active {
  background: var(--primary-bg);
  border-color: var(--primary);
}

.city-item-icon {
  font-size: 28rpx;
}

.city-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.city-item.active .city-item-name {
  color: var(--primary);
}

/* 我的位置特殊样式 */
.city-item.location-item {
  background: linear-gradient(135deg, var(--primary-bg) 0%, #E8FAF8 100%);
  border-color: var(--primary);
}

.city-item.location-item .city-item-name {
  color: var(--primary);
  font-weight: 700;
}

/* 隐藏Canvas：图标生成用 */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}
