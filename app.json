{
  "pages": [
    "pages/index/index",
    "pages/spots/spots",
    "pages/discover/discover",
    "pages/my/my",
    "pages/shop-detail/shop-detail",
    "pages/spot-detail/spot-detail",
    "pages/route/route",
    "pages/wantgo/wantgo",
    "pages/add-shop/add-shop",
    "pages/webview/webview"
  ],
  "lazyCodeLoad": true,
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "觅食图",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "color": "#9CA3AF",
    "selectedColor": "#00D9C0",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "美食",
        "iconPath": "images/tabbar-home.png",
        "selectedIconPath": "images/tabbar-home-active.png"
      },
      {
        "pagePath": "pages/spots/spots",
        "text": "景点",
        "iconPath": "images/tabbar-spots.png",
        "selectedIconPath": "images/tabbar-spots-active.png"
      },
      {
        "pagePath": "pages/discover/discover",
        "text": "发现",
        "iconPath": "images/tabbar-discover.png",
        "selectedIconPath": "images/tabbar-discover-active.png"
      },
      {
        "pagePath": "pages/my/my",
        "text": "我的",
        "iconPath": "images/tabbar-my.png",
        "selectedIconPath": "images/tabbar-my-active.png"
      }
    ]
  },
  "networkTimeout": {
    "request": 10000,
    "downloadFile": 10000
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于展示附近美食"
    }
  },
  "requiredPrivateInfos": [
    "getLocation",
    "chooseLocation"
  ]
}