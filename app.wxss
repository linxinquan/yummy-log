/* ================================================
  觅食图 · 全局设计系统
  圆周旅迹风格 · v3.0
  ================================================ */

/* ─── Design Tokens ─────────────────────────── */
page {
  /* 主色（圆周旅迹标准红） */
  --black:       #111111;
  --white:       #ffffff;
  --accent:      #FF4757;       /* 圆周旅迹红 */
  --accent-soft: #FFF0F1;
  --accent-grad: linear-gradient(135deg, #FF6B6B 0%, #FF4757 100%);

  /* 灰度 */
  --gray-1: #333333;
  --gray-2: #666666;
  --gray-3: #999999;
  --gray-4: #CCCCCC;
  --gray-5: #EBEBEB;
  --gray-6: #F5F5F5;
  --gray-7: #FAFAFA;

  /* 圆角 */
  --r-full: 999rpx;
  --r-xl:   24rpx;
  --r-lg:   20rpx;
  --r-md:   16rpx;
  --r-sm:   12rpx;
  --r-xs:   8rpx;

  /* 阴影 */
  --shadow-sm:  0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md:  0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg:  0 8rpx 24rpx rgba(0,0,0,0.12);
  --shadow-accent: 0 6rpx 20rpx rgba(255,71,87,0.32);

  /* 动效 */
  --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);

  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--black);
  background: var(--gray-7);
  -webkit-font-smoothing: antialiased;
}

/* ─── Layout ─────────────────────────────────── */
.flex         { display: flex; }
.flex-col     { display: flex; flex-direction: column; }
.flex-center  { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap    { flex-wrap: wrap; }
.flex-1       { flex: 1; }

/* ─── Typography ─────────────────────────────── */
.text-center  { text-align: center; }
.text-accent  { color: var(--accent); }
.text-gray    { color: var(--gray-2); }
.text-bold    { font-weight: 700; }
.text-xs      { font-size: 22rpx; }
.text-sm      { font-size: 24rpx; }
.text-base    { font-size: 28rpx; }
.text-lg      { font-size: 32rpx; }
.text-xl      { font-size: 36rpx; }
.text-2xl     { font-size: 44rpx; }
.text-3xl     { font-size: 52rpx; }

/* ─── Spacing ────────────────────────────────── */
.mt-8  { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8  { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-24  { padding: 24rpx; }
.p-32  { padding: 32rpx; }
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }

/* ─── Cards ──────────────────────────────────── */
.card {
  background: var(--white);
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.card-sm {
  background: var(--white);
  border-radius: var(--r-md);
  padding: 20rpx;
  box-shadow: var(--shadow-sm);
}

/* ─── Pills / Chips ──────────────────────────── */
.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: var(--r-full);
  font-size: 26rpx;
  font-weight: 500;
  background: var(--gray-6);
  color: var(--gray-2);
  white-space: nowrap;
  transition: all 0.2s var(--ease);
}

.pill.active {
  background: var(--black);
  color: var(--white);
}

.pill.accent {
  background: var(--accent);
  color: var(--white);
  box-shadow: var(--shadow-accent);
}

/* ─── Tags ───────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: var(--r-full);
  font-size: 22rpx;
  font-weight: 500;
  background: var(--accent-soft);
  color: var(--accent);
}

.tag-gray {
  background: var(--gray-6);
  color: var(--gray-2);
}

/* ─── Buttons ────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 48rpx;
  border-radius: var(--r-full);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.18s var(--ease);
}

.btn-primary {
  background: var(--accent);
  color: var(--white);
  box-shadow: var(--shadow-accent);
}

.btn-dark {
  background: var(--black);
  color: var(--white);
}

.btn-outline {
  background: transparent;
  border: 1.5rpx solid var(--gray-4);
  color: var(--gray-2);
}

.btn-ghost {
  background: var(--gray-6);
  color: var(--gray-1);
}

/* ─── Icon Buttons ───────────────────────────── */
.icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gray-6);
  transition: background 0.18s var(--ease);
}

.icon-btn:active { background: var(--gray-5); }

/* ─── Form ───────────────────────────────────── */
.input {
  width: 100%;
  padding: 22rpx 28rpx;
  border: 1.5rpx solid var(--gray-5);
  border-radius: var(--r-md);
  font-size: 28rpx;
  background: var(--white);
  box-sizing: border-box;
  color: var(--black);
}

/* ─── Shop Card ──────────────────────────────── */
.shop-card {
  display: flex;
  padding: 20rpx 0;
  background: var(--white);
  border-bottom: 1rpx solid var(--gray-5);
}

.shop-emoji {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.shop-info {
  flex: 1;
  min-width: 0;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--black);
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shop-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--gray-2);
  margin-bottom: 10rpx;
}

.shop-rating {
  color: var(--accent);
  font-weight: 600;
}

.shop-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* ─── Divider ────────────────────────────────── */
.divider {
  height: 1rpx;
  background: var(--gray-5);
  margin: 0;
}

/* ─── Modal ──────────────────────────────────── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 999;
}

.modal-content {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--white);
  border-radius: var(--r-xl) var(--r-xl) 0 0;
  max-height: 82vh;
  overflow-y: auto;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-handle {
  width: 72rpx;
  height: 6rpx;
  background: var(--gray-4);
  border-radius: var(--r-full);
  margin: 18rpx auto 0;
}

/* ─── Empty State ────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--gray-3);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--gray-2);
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--gray-3);
  text-align: center;
  padding: 0 60rpx;
  line-height: 1.6;
}

/* ─── Section Header ─────────────────────────── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--black);
}

.section-action {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 600;
}
